# Cloudflare Pages headers
# Note: Content-Encoding KHÔNG set được qua _headers (restricted).
# Client dùng DecompressionStream để manually decompress .gz files.

# Tile data — cache 30 ngày
/data/tiles/*
  Cache-Control: public, max-age=2592000, immutable

/data/search.json.gz
  Cache-Control: public, max-age=604800

# Manifest luôn fresh để phát hiện update
/data/manifest.json
  Cache-Control: public, max-age=60, must-revalidate

# App shell — SW tự update
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Security headers
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(self), camera=(self)
